{
  "name": "@manifestdocs/mcp",
  "version": "0.1.0",
  "description": "Manifest MCP server for Claude Code and Cursor",
  "type": "module",
  "license": "MIT",
  "bin": {
    "manifest-mcp": "dist/index.js"
  },
  "main": "dist/server.js",
  "exports": {
    ".": "./dist/server.js",
    "./client": "./dist/client.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "generate:content": "node ./scripts/generate-content.mjs",
    "build": "node ./scripts/generate-content.mjs && tsc",
    "test": "node ./scripts/generate-content.mjs && vitest",
    "test:run": "node ./scripts/generate-content.mjs && vitest run",
    "check": "node ./scripts/generate-content.mjs && tsc --noEmit",
    "dev:workers": "wrangler dev",
    "deploy:workers": "wrangler deploy"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "jose": "^6.2.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.76.0"
  }
}
